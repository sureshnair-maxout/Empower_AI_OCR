# Application Settings
APP_NAME=Empower AI OCR API
APP_VERSION=1.0.0
APP_ENV=development
API_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
DEBUG=true

# Mode Settings (tenant or owner)
DEPLOYMENT_MODE=tenant
ENABLE_BILLING=true

# Database
DATABASE_URL=postgresql://ocr_user:ocr_password@localhost:5432/ocr_db
DATABASE_POOL_SIZE=10
DATABASE_ECHO=false

# Authentication & Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
JWT_SUBJECT=access_token

# India Compliance
DATA_LOCALIZATION_ENABLED=true
ENFORCE_PII_HANDLING=true
PII_FIELDS=aadhaar_number,pan_number,phone_number,email

# LLM / Ollama Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OCR_MODEL_NAME=glm-ocr
OCR_MODEL_VERSION=latest
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# Document Type Configuration
DOCUMENT_TYPE_CONFIG_PATH=./config/document_types.yaml
MAX_DOCUMENT_SIZE_MB=20
SUPPORTED_FORMATS=jpg,jpeg,png,pdf

# Observability & Monitoring
OTEL_ENABLED=true
OTEL_EXPORTER_TYPE=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis (Caching & Session)
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_MINUTES=60

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=3600

# File Storage
DOCUMENT_STORAGE_PATH=./storage/documents
KEEP_UPLOADED_DOCUMENTS=false
ARCHIVE_JSONS=false
ARCHIVE_PATH=./storage/archive

# Admin Settings
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
ADMIN_API_KEY=your-admin-api-key

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Billing Configuration (Tenant Mode Only)
BILLING_AGGREGATION_FREQUENCY=monthly
BILLING_CURRENCY=INR
DEFAULT_RATE_PER_DOCUMENT=10.00

# Backup & Archival
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * 0
BACKUP_RETENTION_DAYS=30
